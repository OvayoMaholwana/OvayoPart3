<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberGuard AI - Advanced Cybersecurity Assistant" 
        Height="750" Width="1250"
        Background="#0A0F1C"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1A2337"/>
            <Setter Property="Foreground" Value="#E0E7FF"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Header -->
        <Border Background="#0F1629" Height="90" VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,0,0">
                    <TextBlock Text="🔰" FontSize="42" Margin="0,0,15,0"/>
                    <StackPanel>
                        <TextBlock Text="CYBERGUARD AI" FontSize="28" FontWeight="Bold" Foreground="#00F5A0"/>
                        <TextBlock Text="Cybersecurity Intelligence Platform" FontSize="13" Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="Part 3 - Final POE" 
                           HorizontalAlignment="Right" VerticalAlignment="Center" 
                           Margin="0,0,40,0" FontSize="16" Foreground="#64748B"/>
            </Grid>
        </Border>

        <TabControl Margin="0,90,0,0" Background="Transparent" BorderThickness="0" 
                    TabStripPlacement="Top" Padding="0">

            <!-- 1. Chatbot Tab with Bubbles -->
            <TabItem Header="💬 Intelligent Chatbot">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Chat with CyberGuard AI" FontSize="20" FontWeight="Bold" Foreground="#00F5A0" Margin="5,0,0,10"/>

                    <ScrollViewer Grid.Row="1" x:Name="scrollViewer" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="chatPanel" Margin="10"/>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtUserInput" Height="50" FontSize="15" Padding="15,0"
                                 Background="#1F2937" Foreground="White" BorderBrush="#475569"
                                 VerticalContentAlignment="Center" KeyDown="txtUserInput_KeyDown"/>
                        <Button Content="SEND" Grid.Column="1" Margin="10,0,0,0" Height="50"
                                Background="#00F5A0" Foreground="#0F172A" FontWeight="Bold" FontSize="15"
                                Click="btnSend_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- 2. Task Assistant (Click handlers removed) -->
            <TabItem Header="✅ Task Assistant">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <!-- Add New Task -->
                    <GroupBox Header="Add New Cybersecurity Task" Margin="5">
                        <StackPanel Margin="10">
                            <TextBlock Text="Title"/>
                            <TextBox x:Name="txtTaskTitle" Height="30" Margin="0,5"/>
                            <TextBlock Text="Description"/>
                            <TextBox x:Name="txtTaskDesc" Height="80" AcceptsReturn="True" Margin="0,5" TextWrapping="Wrap"/>
                            <TextBlock Text="Reminder (optional)"/>
                            <TextBox x:Name="txtTaskReminder" Height="30" Margin="0,5"/>
                            <Button Content="Add Task" Height="40" Margin="0,10" Background="#00FF88"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Task List -->
                    <GroupBox Header="Your Tasks" Grid.Column="1" Margin="5">
                        <Grid>
                            <ListBox x:Name="lstTasks" Margin="5" Background="#1E2A44" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10">
                                <Button Content="Mark Complete" Height="35" Margin="5" Background="#FFAA00"/>
                                <Button Content="Delete" Height="35" Margin="5" Background="#FF4444"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- 3. Cybersecurity Quiz -->
            <TabItem Header="🎮 Cybersecurity Quiz">
                <Grid Margin="20">
                    <StackPanel>
                        <TextBlock x:Name="txtQuizQuestion" TextWrapping="Wrap" FontSize="18" Margin="10" FontWeight="SemiBold"/>

                        <ListBox x:Name="lstQuizOptions" Margin="10" Height="250" Background="#1E2A44"/>

                        <Button Content="Submit Answer" x:Name="btnSubmitAnswer" Click="btnSubmitAnswer_Click" 
                                Height="45" Margin="10" Background="#00CCFF" FontSize="16"/>

                        <TextBlock x:Name="txtQuizFeedback" TextWrapping="Wrap" Margin="10" FontSize="16"/>

                        <Button Content="Start New Quiz" Click="btnResetQuiz_Click" 
                                HorizontalAlignment="Center" Width="200" Height="40" Margin="10"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- 4. Activity Log -->
            <TabItem Header="📜 Activity Log">
                <Grid Margin="25">
                    <Border Background="#111827" CornerRadius="10" BorderBrush="#334155" BorderThickness="1">
                        <Grid>
                            <ScrollViewer Padding="20">
                                <TextBlock x:Name="txtActivityLog" FontFamily="Consolas" FontSize="14.5" 
                                           Foreground="#67E8F9" TextWrapping="Wrap" LineHeight="22"/>
                            </ScrollViewer>
                            <Button Content="Refresh Log" Click="btnRefreshLog_Click" 
                                    HorizontalAlignment="Right" VerticalAlignment="Top" 
                                    Margin="0,15,20,0" Width="130" Height="38"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>